{
  "name": "deep-novel-typer-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next-types": "node scripts/clean-next-generated-types.mjs",
    "clean:test-output": "node scripts/clean-test-output.mjs",
    "dev": "npm run clean:next-types && next dev",
    "build": "npm run clean:next-types && node scripts/clean-next-build.mjs && next build && node scripts/verify-next-build.mjs",
    "start": "next start",
    "lint": "node scripts/lint-with-timeout.mjs",
    "test": "npm run clean:test-output && tsc -p tsconfig.test.json && node --test .test-build/tests/*.test.js",
    "typecheck": "npm run clean:next-types && tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@uiw/react-md-editor": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-sanitize": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.0",
    "typescript": "^5.7.2"
  }
}
